# Churn Analysis — environment credentials template
# Copy this file to .env and fill in the real values.
# Get the actual values from the team's shared secrets (1Password / Notion).
# NEVER commit .env — it is in .gitignore.

# ── Auth (single shared password) ────────────────────────
AUTH_PASSWORD=          # password users type on /login
AUTH_SECRET=            # random secret stored in the cookie (generate with: openssl rand -hex 32)

# ── ClickHouse (Gallabox analytics cluster) ───────────────
CH_HOST=https://<cluster-id>.ap-southeast-1.aws.clickhouse.cloud:8443
CH_USER=default
CH_PASS=

# ── Chargebee ─────────────────────────────────────────────
CB_SITE=gallaboxglobal.chargebee.com
CB_KEY=

# ── Zoho (CRM + Desk) ─────────────────────────────────────
# OAuth tokens — auto-refreshed by zoho_auth.py
ZOHO_DESK_ORG_ID=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# ── Amplitude ─────────────────────────────────────────────
AMPLITUDE_API_KEY=
AMPLITUDE_SECRET_KEY=
