# Churn Analysis — environment credentials template
# Copy this file to .env and fill in the real values.
# NEVER commit .env — it is in .gitignore.

# ── PocketBase ────────────────────────────────────────────
PB_EMAIL=admin@yourdomain.com
PB_PASSWORD=

# ── Auth (single shared password for the dashboard) ──────
AUTH_PASSWORD=
AUTH_SECRET=       # generate with: openssl rand -hex 32
SECURE_COOKIE=true # set to true only when serving over HTTPS

# ── ClickHouse ────────────────────────────────────────────
CH_HOST=https://<cluster-id>.ap-southeast-1.aws.clickhouse.cloud:8443
CH_USER=default
CH_PASS=

# ── Chargebee ─────────────────────────────────────────────
CB_SITE=gallaboxglobal.chargebee.com
CB_KEY=

# ── Zoho (CRM + Desk) ─────────────────────────────────────
ZOHO_DESK_ORG_ID=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# ── Amplitude ─────────────────────────────────────────────
AMPLITUDE_API_KEY=
AMPLITUDE_SECRET_KEY=
AMPLITUDE_ACCOUNT_PROP=   # optional: group property name to filter by account (e.g. "account_id")
